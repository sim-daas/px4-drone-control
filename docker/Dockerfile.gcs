# GCS Dashboard — Lightweight web container
FROM python:3.10-slim

WORKDIR /app

# Install Python dependencies
COPY gcs/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy application files
COPY gcs/ /app/
COPY shared/ /app/shared/

EXPOSE ${GCS_PORT:-8080}

CMD ["python3", "app.py"]
